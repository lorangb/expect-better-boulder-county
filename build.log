from html.parser import HTMLParser
import sys
class V(HTMLParser):
    def __init__(self):
        super().__init__()
        self.stack=[]
        self.errors=[]
    def handle_starttag(self,tag,attrs):
        if tag not in ('br','img','meta','link','input','hr','source','area','base','col','embed','param','track','wbr','path','stop','use'):
            self.stack.append(tag)
    def handle_endtag(self,tag):
        if self.stack and self.stack[-1]==tag:
            self.stack.pop()
        else:
            # try to find match deeper
            if tag in self.stack:
                while self.stack and self.stack[-1]!=tag:
                    self.errors.append('unclosed '+self.stack[-1])
                    self.stack.pop()
                if self.stack: self.stack.pop()
            else:
                self.errors.append('stray close '+tag)
p=V()
with open('/opt/data/cemex-content/new-site/index.html') as f:
    p.feed(f.read())
print('Remaining open tags:', p.stack[-10:] if p.stack else 'NONE')
print('Issues:', p.errors[:20] if p.errors else 'NONE')
print('Total issues:', len(p.errors))
